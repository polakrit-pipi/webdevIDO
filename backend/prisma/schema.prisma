
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  documentId String  @unique @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  firstname String?
  lastname  String?
  phone     String?
  address   Json?    // { line1, subdistrict, district, province, zipcode }
  role      String   @default("authenticated")
  provider  String   @default("local")
  confirmed Boolean  @default(true)
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cart         Cart?
  wishlists    Wishlist[]
  transactions Transaction[]

  @@map("users")
}

// ============================================
// Administrator 
// ============================================
model Admin {
  id        Int      @id @default(autoincrement())
  documentId String  @unique @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  firstname String?
  lastname  String?
  address   Json?    // { line1, subdistrict, district, province, zipcode }
  age       Int?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loginLogs AdminLoginLog[]

  @@map("admins")
}

// ============================================
// Administrator Login Log 
// ============================================
model AdminLoginLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  loginTime DateTime @default(now())
  ipAddress String?
  status    String   @default("SUCCESS") // SUCCESS, FAILED
  
  @@map("admin_login_logs")
}

// ============================================
// Product
// ============================================
model Product {
  id          Int      @id @default(autoincrement())
  documentId  String   @unique @default(uuid())
  ProductName String
  recomended  Boolean  @default(false)
  description Json?
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  categoryId  Int?
  cat_pro     Category?  @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  wishlists   Wishlist[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  newProduct  NewProduct?

  @@map("products")
}

model ProductVariant {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  color       String?
  size        String?
  stockqty    Int?     @default(0)
  pricing     Decimal  @default(0)
  salePricing Int?     @default(0)
  Image       Json?    // Array of { url: string } objects

  // Relations
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

// ============================================
// Category
// ============================================
model Category {
  id           Int      @id @default(autoincrement())
  documentId   String   @unique @default(uuid())
  categoryName String
  categoryPic  Json?    // { url: string }
  type         String?  // "shirt" | "trouser" | "others"
  publishedAt  DateTime? @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  pro_cats     Product[]

  @@map("categories")
}

// ============================================
// Collection
// ============================================
model Collection {
  id          Int      @id @default(autoincrement())
  documentId  String   @unique @default(uuid())
  Image       Json?    // { url: string }
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("collections")
}

// ============================================
// Banner (single-type: only 1 row expected)
// ============================================
model Banner {
  id          Int      @id @default(autoincrement())
  documentId  String   @unique @default(uuid())
  Image       Json?    // { url: string }
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("banners")
}

// ============================================
// Color (single-type: only 1 row expected)
// ============================================
model Color {
  id          Int      @id @default(autoincrement())
  documentId  String   @unique @default(uuid())
  color       Json?    // Theme color config JSON
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("colors")
}

// ============================================
// NewProduct (featured/new arrivals)
// ============================================
model NewProduct {
  id          Int      @id @default(autoincrement())
  documentId  String   @unique @default(uuid())
  Image       Json?    // { url: string }
  title       String?
  description String?
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  productId   Int?     @unique
  product     Product? @relation(fields: [productId], references: [id])

  @@map("new_products")
}

// ============================================
// Cart
// ============================================
model Cart {
  id          Int      @id @default(autoincrement())
  documentId  String   @unique @default(uuid())
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CartItem[]

  @@map("carts")
}

// ============================================
// CartItem 
// ============================================
model CartItem {
  id            Int       @id @default(autoincrement())
  sku           String?
  quantity      Int       @default(1)
  price_at_added Decimal?
  added_at      DateTime? @default(now())

  // Relations
  cartId        Int
  cart          Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId     Int?
  product       Product?  @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

// ============================================
// Wishlist
// ============================================
model Wishlist {
  id          Int       @id @default(autoincrement())
  documentId  String    @unique @default(uuid())
  added_at    DateTime? @default(now())
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product?  @relation(fields: [productId], references: [id])

  @@map("wishlists")
}

// ============================================
// Transaction (Order)
// ============================================
model Transaction {
  id             Int       @id @default(autoincrement())
  documentId     String    @unique @default(uuid())
  order_status   String?   @default("Pending") // Pending, Shipped, Delivered, Cancelled
  total_summary  Decimal?
  tracking_info  String?
  publishedAt    DateTime? @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  userId         Int
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          OrderItem[]

  @@map("transactions")
}

// ============================================
// OrderItem
// ============================================
model OrderItem {
  id               Int      @id @default(autoincrement())
  quantity         Int      @default(1)
  price_at_purchase Decimal?
  selected_sku     String?

  // Relations
  transactionId    Int
  transaction      Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId        Int?
  product          Product?    @relation(fields: [productId], references: [id])

  @@map("order_items")
}
